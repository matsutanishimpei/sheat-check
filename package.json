{
  "name": "my-app-monorepo",
  "private": true,
  "description": "Seats & Check Studio - リアルタイム座席配置・理解度監視システム",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matsutanishimpei/sheat-check.git"
  },
  "bugs": {
    "url": "https://github.com/matsutanishimpei/sheat-check/issues"
  },
  "homepage": "https://github.com/matsutanishimpei/sheat-check#readme",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev:backend": "npm run dev --workspace=@my-app/backend",
    "dev:frontend": "npm run dev --workspace=@my-app/frontend",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present"
  },
  "devDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@vitest/coverage-v8": "4.1.6",
    "drizzle-orm": "^0.45.2",
    "vitest": "4.1.6",
    "wrangler": "3.57.2"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.21.5"
  }
}
